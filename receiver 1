void lcd_init(void)
{
	IODIR0|=lcd_d|rs|e;
	lcd_cmd(0x01);
	lcd_cmd(0x02);
	lcd_cmd(0x0c);
	lcd_cmd(0x28);
	lcd_cmd(0x80);
}

void lcd_cmd(unsigned char cmd)
{
   IOCLR0=lcd_d;
	IOSET0=(cmd&(0xf0))<<6;
	IOCLR0=rs;
	IOSET0=e;
	delay_ms(2);
	IOCLR0=e;

	IOCLR0=lcd_d;
	IOSET0=(cmd&(0x0f))<<10;
	IOCLR0=rs;
	IOSET0=e;
	delay_ms(2);
	IOCLR0=e;
}

void lcd_data(unsigned char d)
{
	IOCLR0=lcd_d;
	IOSET0=(d&(0xf0))<<6;
	IOSET0=rs;
	IOSET0=e;
	delay_ms(2);
	IOCLR0=e;

	IOCLR0=lcd_d;
	IOSET0=(d&(0x0f))<<10;
	IOSET0=rs;
	IOSET0=e;
	delay_ms(2);
	IOCLR0=e;
}


void lcd_float(int n)
{
	unsigned char arr[5];
	signed char i=0;
	if(n==0)
	{
		lcd_data('0');
	}
	else
	{
		if(n<0)
		{
			lcd_data('-');
			n=-n;
		}
		while(n>0)
		{
			arr[i++]=n%10;
			n=n/10;
		}
		for(i=i-1;i>=0;i--)
		{
			lcd_data(arr[i]+48);
		}
	}
}
void lcd_string(unsigned char* s)
{
	while(*s)
	{
		lcd_data(*s++);
	}
}


void uart1_init(void)
{
	PINSEL0|=5<<16;
	U1LCR=0x83;
	U1DLL=32;
	U1DLM=0;
	U1LCR=0x03;
}

void uart1_tx(unsigned char txbyte)
{
	while(((U1LSR>>5)&1)==0);
		U1THR=txbyte;
}

void uart1_string(unsigned char* s)
{
	while(*s)
	{
		uart1_tx(*s++);
	}
}

void uart1_hex(int num)
{
	char buf[10];
	sprintf(buf,"%X",num);
	uart1_string(buf);
 
}
