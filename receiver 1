void servo_init(void);
void servo_write(int);
void lcd_init(void);
void lcd_cmd(unsigned char);
void lcd_data(unsigned char);
void lcd_float(int);
void lcd_string(unsigned char *);
void uart1_init(void);
void uart1_tx(unsigned char);
void uart1_string(unsigned char*);
void uart1_hex(int num);
void delay_ms(int ms)
{
	T0PR=60000-1;
	T0TCR=0x01;
	while(T0TC<ms);
	T0TCR=0x03;
	T0TCR=0x00;
}



int main()
{
	IODIR0=3<<0;
	can_init();
	lcd_init();
	
	uart1_init();
	servo_init();
	lcd_string("temperature");
	while(1)
	{	 
		can_rx(&n);
		
		
		
		uart1_hex(n.mid);
		uart1_tx(' ');
		uart1_hex(n.rtr);
		uart1_tx(' ');
		uart1_hex(n.dlc);
		uart1_tx(' ');
		uart1_hex(n.data1);
		uart1_tx(' ');
		uart1_hex(n.data2);
		uart1_tx(' ');
		uart1_string("\r\n");
	
		if(n.data1>30)
		{
			servo_write(2000);
		}
		else if(n.data1<30)
		{
			servo_write(1000);
		}
		else
		{	
			servo_write(1500);
		}
		lcd_cmd(0xc0);
		lcd_float(n.data1);
		delay_ms(3000);
		lcd_cmd(0x01);
	}
}

