#include<lpc21xx.h>
#include<stdio.h>
#define lcd_d 0xf<<10
#define rs 1<<8
#define e 1<<9
typedef unsigned int u32;

struct can
{
	u32 mid;
	u32 rtr;
	u32 dlc;
	u32 data1;
	u32 data2;
};
struct can n;

void can_init(void);
