{
	PINSEL1=5<<14;
	VPBDIV=1;
	C2MOD=1<<0;
	AFMR=1<<1;
	C2BTR|=0x1D;
	C2MOD=0x0;
}

void can_rx(struct can* m)
{
	while(((C2GSR>>0)&1)==0);
	
	m->mid=C2RID;
	m->rtr=((C2RFS>>30)&1);
	m->dlc=((C2RFS>>16)&0x0f);
	m->data1=C2RDA;
	m->data2=C2RDB;
	
	C2CMR=1<<2;
}

